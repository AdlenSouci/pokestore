# Copier vers .env en local — sur Render, coller les mêmes clés dans Environment

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=changez-moi-en-production
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your-google-app-password
MAIL_FROM=PokéStore <your@gmail.com>
CONTACT_TO=your@gmail.com

# Production Render (plan gratuit) : SMTP port 587 bloqué → utiliser Resend (HTTPS)
# Créer un compte sur https://resend.com → API Keys → coller la clé re_...
RESEND_API_KEY=
RESEND_FROM=PokéStore <onboarding@resend.dev>

# Secret pour signer les captchas du formulaire contact (optionnel, sinon JWT_SECRET)
CAPTCHA_SECRET=
CAPTCHA_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

FRONTEND_URL=http://localhost:5173

POKEMON_TCG_SET_IDS=sv1,swsh12,xy1
POKEMON_TCG_API_KEY=
